[
  {
    "exclusive": true,
    "description": "Large cup size → Big Tits",
    "if": { "cup_category": { "any": ["large"] } },
    "then": { "add": ["Big Tits"] }
  },
  {
    "exclusive": true,
    "description": "Medium cup size → Medium Tits",
    "if": { "cup_category": { "any": ["medium"] } },
    "then": { "add": ["Medium Tits"] }
  },
  {
    "exclusive": true,
    "description": "Small cup size → Small Tits",
    "if": { "cup_category": { "any": ["small"] } },
    "then": { "add": ["Small Tits"] }
  },
  {
    "description": "European performer",
    "if": {
      "country": {
        "any": [
          "AL", "AD", "AT", "BY", "BE", "BA", "BG", "HR", "CY", "CZ",
          "DK", "EE", "FI", "FR", "DE", "GR", "HU", "IS", "IE", "IT",
          "XK", "LV", "LI", "LT", "LU", "MT", "MD", "MC", "ME", "NL",
          "MK", "NO", "PL", "PT", "RO", "RU", "SM", "RS", "SK", "SI",
          "ES", "SE", "CH", "UA", "GB", "VA"
        ]
      }
    },
    "then": { "add": ["European"] }
  },
  {
    "description": "Remove incorrect European tag when performer is not European",
    "if": {
      "tags": { "any": ["European"] },
      "country": {
        "none": [
          "AL", "AD", "AT", "BY", "BE", "BA", "BG", "HR", "CY", "CZ",
          "DK", "EE", "FI", "FR", "DE", "GR", "HU", "IS", "IE", "IT",
          "XK", "LV", "LI", "LT", "LU", "MT", "MD", "MC", "ME", "NL",
          "MK", "NO", "PL", "PT", "RO", "RU", "SM", "RS", "SK", "SI",
          "ES", "SE", "CH", "UA", "GB", "VA"
        ]
      }
    },
    "then": { "remove": ["European"] }
  },
  {
    "description": "Japanese performer",
    "if": { "country": { "any": ["JP"] } },
    "then": { "add": ["Japanese"] }
  },
  {
    "description": "Latin American performer → tag as Latin",
    "if": {
      "country": {
        "any": [
