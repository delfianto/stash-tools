# Copy to .env and fill in your values.

# ── Stash connection ──────────────────────────────────────────────────────────
STASH_SCHEME=http
STASH_HOST=localhost
STASH_PORT=9999
STASH_API_KEY=
STASH_API_KEY_DB=
STASH_DB_ENDPOINT=https://stashdb.org/graphql

# How many scenes/performers to process in parallel. Higher = faster but more load on Stash and StashDB.
STASH_CONCURRENCY=5

# Path to the declarative tag rules file (JSON). Reloaded on every tag run.
STASH_TAG_RULES_FILE=./rules/scene.json

# Path to the performer tag rules file (JSON). Reloaded on every tag run.
STASH_PERFORMER_RULES_FILE=./rules/performer.json

# ── Renamer ───────────────────────────────────────────────────────────────────
# Root directory to scan for unorganized files (Renamer feature only)
RENAMER_SOURCE=/mnt/data/stash/Origin

# Base directory where organized files are moved
RENAMER_DEST=/mnt/data/stash/Studio

# Docker-to-host path mapping as JSON (omit if not using Docker)
# Example: RENAMER_PATH_MAP={"/media":"/mnt/data/stash"}
RENAMER_PATH_MAP={}

# Directory structure under RENAMER_DEST
# Variables: {studio} {parent_studio} {studio_or_parent} {performers} {date} {title}
RENAMER_DIR_STRUCTURE={studio_or_parent}

# Filename pattern (extension added automatically)
# Variables: same as above plus {performers_first} {ext}
RENAMER_FILE_STRUCTURE={studio} - {date} - {performers} - {title}

# Set to true to produce Studio.Name.mp4 style filenames
RENAMER_DOTS=false

# Date format using strftime codes: %Y=2024 %y=24 %m=11 %d=30
RENAMER_DATE_FORMAT=%y.%m.%d
