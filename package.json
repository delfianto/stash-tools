{
  "name": "stash-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch server/index.ts",
    "dev:ui": "vp dev",
    "start": "bun server/index.ts",
    "build": "vue-tsc -p tsconfig.json --noEmit && vp build",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "lint": "vp lint src",
    "prepare": "vp config"
  },
  "dependencies": {
    "@vueuse/core": "^13.1.0",
    "hono": "^4.7.11",
    "lucide-vue-next": "^0.511.0",
    "pinia": "^3.0.2",
    "pino": "^9.7.0",
    "reka-ui": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-sonner": "^2.0.3",
    "zod": "^3.25.48"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "latest",
    "@vitejs/plugin-vue": "^6.0.7",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vue-tsc": "^3.3.1"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "bun@1.3.14"
}
